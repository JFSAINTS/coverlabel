{
  "name": "coverlabel",
  "version": "1.6.0",
  "description": "Etiquetas y portadas listas para imprimir",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.jfsaints.coverlabel",
    "productName": "CoverLabel",
    "copyright": "Copyright © 2026 JFSAINTS",
    "directories": { "output": "dist" },
    "files": [
      "index.html",
      "manifest.json",
      "sw.js",
      "lib/**",
      "icons/**",
      "templates/**",
      "electron-main.js"
    ],
    "win": {
      "icon": "icons/icon.ico",
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CoverLabel"
    }
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0"
  }
}
